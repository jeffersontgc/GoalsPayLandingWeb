# Public URL to the latest APK build (e.g. GitHub Releases, S3, EAS Build URL)
# Leave empty to disable the download CTA (the button will show a friendly toast)
NEXT_PUBLIC_APK_URL=

# Store URLs (leave empty until published; the badges will render as "coming soon")
NEXT_PUBLIC_PLAY_STORE_URL=
NEXT_PUBLIC_APP_STORE_URL=

# Canonical site URL (used for SEO + sitemap)
NEXT_PUBLIC_SITE_URL=https://goalspay.app
